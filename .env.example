# TrafficVision AI - Environment Configuration
# Copy this to .env and fill in production values

# ── Database ──
POSTGRES_USER=trafficvision
POSTGRES_PASSWORD=devpassword
POSTGRES_DB=trafficvision
DATABASE_URL=postgresql+asyncpg://trafficvision:devpassword@db:5432/trafficvision

# ── Redis / Broker ──
REDIS_URL=redis://broker:6379/0
CELERY_BROKER_URL=redis://broker:6379/0
CELERY_RESULT_BACKEND=redis://broker:6379/1

# ── Backend ──
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
CORS_ORIGINS=http://localhost:3000

# ── JWT / Auth ──
SECRET_KEY=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ── CV Pipeline ──
# Enable real model inference (requires GPU). Defaults to false (mock mode).
USE_REAL_MODELS=false
# Target device: "cuda" or "cpu". Auto-detected if CUDA is available.
DEVICE=cuda
# Directory for cached model weights (EasyOCR downloads, fine-tuned YOLOs).
MODEL_CACHE_DIR=/app/models

# ── Object Storage (optional) ──
# S3_ENDPOINT_URL=http://minio:9000
# S3_ACCESS_KEY=minioadmin
# S3_SECRET_KEY=minioadmin
# S3_BUCKET_NAME=trafficvision-evidence
